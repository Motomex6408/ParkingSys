@model List<Entity.Administrador.eTarifa>

@{
    ViewBag.Title = "Gestión de Tarifas";
}

<div class="container-fluid p-0">
    <div class="card shadow-sm border-0" style="background: white !important; border-radius: 15px; margin-bottom: 20px;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="page-header-title p-4 d-flex align-items-center">
                    <div style="width:55px; height:55px; border-radius:12px; background-color: #933ec5 !important; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(147, 62, 197, 0.4);" class="mr-3">
                        <i class="icofont icofont-cur-dollar" style="font-size:26px; color: #ffffff !important;"></i>
                    </div>

                    <div class="d-inline">
                        <h4 class="f-w-600 m-b-0" style="color: #222 !important;">Listado de Tarifas</h4>
                        <p class="m-b-0" style="color: #555 !important;">Configure los precios por hora, día y mes para cada sucursal</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 text-right p-4">
                <a href="@Url.Action("Create")" class="btn btn-primary btn-round shadow-blue" style="background-color: #448aff !important; border:none; padding: 10px 25px; color: #ffffff !important; font-weight: 600;">
                    <i class="icofont icofont-plus m-r-5"></i> Nueva Tarifa
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-block p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr>
                            <th class="p-4 border-0 text-dark f-w-600">Sucursal / Vehículo</th>
                            <th class="p-4 border-0 text-dark f-w-600">Nombre</th>
                            <th class="p-4 border-0 text-dark f-w-600 text-center">Precio Hora</th>
                            <th class="p-4 border-0 text-dark f-w-600 text-center">Precio Día</th>
                            <th class="p-4 border-0 text-dark f-w-600 text-center">Precio Mes</th>
                            <th class="p-4 border-0 text-dark f-w-600 text-center">Vigencia</th>
                            <th class="p-4 border-0 text-dark f-w-600 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="p-4 align-middle">
                                    <div class="d-inline-block align-middle">
                                        <h6 class="m-b-0 f-w-600" style="color: #444;">@(item.Sucursal != null ? item.Sucursal.Nombre : "N/A")</h6>
                                        <p class="m-b-0 text-muted small">@(item.TipoVehiculo != null ? item.TipoVehiculo.Nombre : "Cualquier vehículo")</p>
                                    </div>
                                </td>
                                <td class="p-4 align-middle">
                                    <span class="text-dark">@item.Nombre</span>
                                </td>
                                <td class="p-4 align-middle text-center">
                                    <span class="f-w-600 text-primary">L. @item.PrecioHora.ToString("N2")</span>
                                </td>
                                <td class="p-4 align-middle text-center text-muted">
                                    L. @item.PrecioDia.ToString("N2")
                                </td>
                                <td class="p-4 align-middle text-center text-muted">
                                    L. @item.PrecioMes.ToString("N2")
                                </td>
                                <td class="p-4 align-middle text-center small">
                                    <span class="d-block text-dark">@item.VigenciaInicio.ToShortDateString()</span>
                                    <span class="text-muted">al</span>
                                    <span class="d-block text-dark">@item.VigenciaFin.ToShortDateString()</span>
                                </td>
                                <td class="p-3 text-center">
                                    <div class="d-flex justify-content-center">
                                        <a href="@Url.Action("Edit", new { id = item.Id })"
                                           class="btn-action edit shadow-sm mr-2"
                                           title="Editar">
                                            <i class="icofont icofont-ui-edit">Editar</i>
                                        </a>

                                        <a href="@Url.Action("Delete", new { id = item.Id })"
                                           class="btn-action delete shadow-sm"
                                           title="Eliminar">
                                            <i class="icofont icofont-ui-delete">Eliminar</i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .f-w-600 {
        font-weight: 600;
    }

    .btn-round {
        border-radius: 50px !important;
    }

    .shadow-blue {
        box-shadow: 0 4px 15px rgba(68, 138, 255, 0.4) !important;
    }

    
    .btn-action {
        width: 90px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 16px;
    }

        
        .btn-action.edit {
            background-color: #e8f0fe;
            color: #448aff;
        }

            .btn-action.edit:hover {
                background-color: #448aff;
                color: white;
                transform: scale(1.1);
            }

        
        .btn-action.delete {
            background-color: #ffebee;
            color: #f44336;
        }

            .btn-action.delete:hover {
                background-color: #f44336;
                color: white;
                transform: scale(1.1);
            }

   
    .mr-2 {
        margin-right: 8px;
    }

    .align-middle {
        vertical-align: middle !important;
    }

   
    .table-hover tbody tr:hover {
        background-color: rgba(68, 138, 255, 0.02);
    }
</style>
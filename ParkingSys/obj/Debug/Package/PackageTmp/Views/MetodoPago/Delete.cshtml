@model Entity.Facturacion.eMetodoPago

@{
    ViewBag.Title = "Eliminar Método de Pago";
}

<h2>Eliminar Método de Pago</h2>

<h4>¿Estás seguro que deseas eliminar esto?</h4>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        <dt>Descripción</dt>
        <dd>@Model.Descripcion</dd>

        <dt>Activo</dt>
        <dd>@Model.Activo</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <input type="submit" value="Eliminar" class="btn btn-danger" />
    }

    <br />
    @Html.ActionLink("Cancelar", "Index")
</div>
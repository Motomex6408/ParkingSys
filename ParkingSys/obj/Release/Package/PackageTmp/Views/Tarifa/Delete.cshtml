@model Entity.Administrador.eTarifa

@{
    ViewBag.Title = "Eliminar Tarifa";
}

<div class="container-fluid p-0">
    <div class="card shadow-sm border-0" style="background: #ffffff !important; border-radius: 15px; margin-bottom:20px;">
        <div class="card-block p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div style="width:55px; height:55px; border-radius:12px; background-color: #FF5370 !important; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(255, 83, 112, 0.4);" class="mr-3">
                        <i class="icofont icofont-trash" style="font-size:26px; color: #ffffff !important;"></i>
                    </div>
                    <div>
                        <h4 class="f-w-600 m-b-0" style="color: #222 !important;">Eliminar Tarifa</h4>
                        <p class="m-b-0 text-danger f-w-600">¿Seguro que desea eliminar esta configuración de precios?</p>
                    </div>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-primary btn-round shadow-sm" style="background-color: #448aff !important; border:none; padding: 10px 25px; color: #ffffff !important;">
                    <i class="icofont icofont-arrow-left"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="background: #ffffff !important; border-radius: 15px;">
        <div class="card-block p-4">
            <div class="row">
                <div class="col-md-12">
                    <h5 class="m-b-25 f-w-600" style="color: #222 !important; border-bottom: 2px solid #FF5370; display: inline-block; padding-bottom: 5px;">Resumen de la Tarifa</h5>
                </div>

                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th class="text-dark" style="width: 150px;">Sucursal:</th>
                            <td class="text-muted">@(Model.Sucursal != null ? Model.Sucursal.Nombre : "No asignada")</td>
                        </tr>
                        <tr>
                            <th class="text-dark">Tipo Vehículo:</th>
                            <td class="text-muted">@(Model.TipoVehiculo != null ? Model.TipoVehiculo.Nombre : "Todos")</td>
                        </tr>
                        <tr>
                            <th class="text-dark">Nombre:</th>
                            <td class="text-muted f-w-600">@Model.Nombre</td>
                        </tr>
                    </table>
                </div>

                <div class="col-md-6" style="border-left: 1px solid #eee;">
                    <table class="table table-borderless">
                        <tr>
                            <th class="text-dark">Precio Hora:</th>
                            <td class="text-primary f-w-700">L. @Model.PrecioHora.ToString("N2")</td>
                        </tr>
                        <tr>
                            <th class="text-dark">Precio Día:</th>
                            <td class="text-muted">L. @Model.PrecioDia.ToString("N2")</td>
                        </tr>
                        <tr>
                            <th class="text-dark">Precio Mes:</th>
                            <td class="text-muted">L. @Model.PrecioMes.ToString("N2")</td>
                        </tr>
                    </table>
                </div>

                <div class="col-md-12 m-t-20">
                    <hr />
                    <div class="alert alert-warning border-0 shadow-sm" style="background-color: #fff9ec; color: #856404; border-radius: 10px;">
                        <i class="icofont icofont-warning-alt m-r-10" style="font-size: 18px;"></i>
                        <strong>Importante:</strong> Al eliminar esta tarifa, los nuevos ingresos a esta sucursal no podrán utilizar estos precios.
                    </div>

                    <div class="text-right">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(model => model.Id)

                            <button type="submit" class="btn btn-danger btn-round shadow-danger px-5 py-2 text-white f-w-700">
                                <i class="icofont icofont-ui-delete m-r-10"></i> CONFIRMAR ELIMINACIÓN
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
  
    .btn-round {
        border-radius: 50px !important;
    }

    .btn-danger {
        background-color: #FF5370 !important;
        border: none !important;
        color: #ffffff !important;
        font-weight: 700 !important;
    }

    .shadow-danger {
        box-shadow: 0 4px 15px rgba(255, 83, 112, 0.4) !important;
    }

    .text-dark {
        color: #222 !important;
    }

    .f-w-700 {
        font-weight: 700;
    }

    .f-w-600 {
        font-weight: 600;
    }

    
    .table-borderless th {
        padding: 10px 0;
        font-weight: 600;
    }

    .table-borderless td {
        padding: 10px 0;
    }
</style>
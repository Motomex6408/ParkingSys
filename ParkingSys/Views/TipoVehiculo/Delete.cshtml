@model Entity.General.eTipoVehiculo

@{
    ViewBag.Title = "Eliminar Tipo de Vehículo";
}

<h2>Eliminar Tipo de Vehículo</h2>

<h4>¿Estás seguro que deseas eliminar esto?</h4>

<div>
    <hr />

    <dl class="dl-horizontal">
        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        <dt>Descripción</dt>
        <dd>@Model.Descripcion</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <input type="submit" value="Eliminar" class="btn btn-danger" />
    }

    <br />
    @Html.ActionLink("Cancelar", "Index")
</div>
@model Entity.Estructura.eZona

@{
    ViewBag.Title = "Eliminar Zona";
}

<h2>Eliminar Zona</h2>

<h4>¿Estás seguro que deseas eliminar esto?</h4>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Sucursal</dt>
        <dd>@(Model.Sucursal != null ? Model.Sucursal.Nombre : "")</dd>

        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        <dt>Descripción</dt>
        <dd>@Model.Descripcion</dd>

        <dt>Nivel</dt>
        <dd>@Model.Nivel</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <input type="submit" value="Eliminar" class="btn btn-danger" />
    }

    <br />
    @Html.ActionLink("Cancelar", "Index")
</div>
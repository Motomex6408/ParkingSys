@model Entity.Administrador.eTarifa

@{
    ViewBag.Title = "Editar Tarifa";
}

<div class="container-fluid p-0">
    <div class="card shadow-sm border-0" style="background: white !important; border-radius: 15px; margin-bottom:20px;">
        <div class="card-block p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div style="width:55px; height:55px; border-radius:12px; background-color: #FFB64D !important; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(255, 182, 77, 0.4);" class="mr-3">
                        <i class="icofont icofont-ui-edit" style="font-size:26px; color: #ffffff !important;"></i>
                    </div>
                    <div>
                        <h4 class="f-w-600 m-b-0" style="color: #222 !important;">Editar Tarifa</h4>
                        <p class="m-b-0 text-muted">Modifique los costos y periodos de vigencia establecidos</p>
                    </div>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-primary btn-round shadow-sm" style="background-color: #448aff !important; border:none; padding: 10px 25px; color: #ffffff !important;">
                    <i class="icofont icofont-arrow-left"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="background: #ffffff !important; border-radius: 15px;">
        <div class="card-block p-4">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Id)

                if (ViewBag.message != null)
                {
                    <div class="alert alert-danger border-0 shadow-sm">
                        <i class="icofont icofont-error-box m-r-10"></i> @ViewBag.message
                    </div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="m-b-25 f-w-600" style="color: #222 !important; border-bottom: 2px solid #FFB64D; display: inline-block; padding-bottom: 5px;">Asignación</h5>

                        <div class="form-group m-t-10">
                            <label class="f-w-600 text-dark">Sucursal</label>
                            @Html.DropDownList("IdSucursal", null, "-- Seleccione --", new { @class = "form-control custom-input" })
                            @Html.ValidationMessageFor(model => model.IdSucursal, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group">
                            <label class="f-w-600 text-dark">Tipo de Vehículo</label>
                            @Html.DropDownList("IdTipoVehiculo", null, "-- Seleccione --", new { @class = "form-control custom-input" })
                            @Html.ValidationMessageFor(model => model.IdTipoVehiculo, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group">
                            <label class="f-w-600 text-dark">Nombre de la Tarifa</label>
                            @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control custom-input" } })
                            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="col-md-6" style="border-left: 1px solid #eee;">
                        <h5 class="m-b-25 f-w-600" style="color: #222 !important; border-bottom: 2px solid #FFB64D; display: inline-block; padding-bottom: 5px;">Costos y Vigencia</h5>

                        <div class="row m-t-10">
                            <div class="col-md-4">
                                <label class="f-w-600 text-dark">Precio Hora</label>
                                @Html.EditorFor(model => model.PrecioHora, new { htmlAttributes = new { @class = "form-control custom-input text-right" } })
                                @Html.ValidationMessageFor(model => model.PrecioHora, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="f-w-600 text-dark">Precio Día</label>
                                @Html.EditorFor(model => model.PrecioDia, new { htmlAttributes = new { @class = "form-control custom-input text-right" } })
                                @Html.ValidationMessageFor(model => model.PrecioDia, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="f-w-600 text-dark">Precio Mes</label>
                                @Html.EditorFor(model => model.PrecioMes, new { htmlAttributes = new { @class = "form-control custom-input text-right" } })
                                @Html.ValidationMessageFor(model => model.PrecioMes, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="row m-t-20">
                            <div class="col-md-6">
                                <label class="f-w-600 text-dark">Vigencia Inicio</label>
                                @Html.TextBoxFor(model => model.VigenciaInicio, "{0:yyyy-MM-dd}", new { @class = "form-control custom-input", type = "date" })
                                @Html.ValidationMessageFor(model => model.VigenciaInicio, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6">
                                <label class="f-w-600 text-dark">Vigencia Fin</label>
                                @Html.TextBoxFor(model => model.VigenciaFin, "{0:yyyy-MM-dd}", new { @class = "form-control custom-input", type = "date" })
                                @Html.ValidationMessageFor(model => model.VigenciaFin, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12 m-t-30">
                        <hr />
                        <div class="text-right">
                            <button type="submit" class="btn btn-warning btn-round shadow-warning px-5 py-2 text-white f-w-700">
                                <i class="icofont icofont-refresh m-r-10"></i> ACTUALIZAR TARIFA
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
   
    .custom-input {
        border-radius: 8px !important;
        border: 1px solid #ced4da !important;
        padding: 10px !important;
    }

    .btn-round {
        border-radius: 50px !important;
    }

    .btn-warning {
        background-color: #FFB64D !important;
        border: none !important;
        color: #ffffff !important;
    }

    .shadow-warning {
        box-shadow: 0 4px 15px rgba(255, 182, 77, 0.4) !important;
    }

    .text-dark {
        color: #333 !important;
    }

    .f-w-700 {
        font-weight: 700;
    }

    .f-w-600 {
        font-weight: 600;
    }
</style>
@model List<Entity.General.eTicket>

@{
    ViewBag.Title = "Dashboard";
}

<div class="row">
    <div class="col-md-3">
        <div class="card bg-c-green text-white">
            <div class="card-block">
                <h4>@ViewBag.EspaciosDisponibles</h4>
                <p class="m-b-0">Espacios Disponibles</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-c-red text-white">
            <div class="card-block">
                <h4>@ViewBag.EspaciosOcupados</h4>
                <p class="m-b-0">Espacios Ocupados</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-c-blue text-white">
            <div class="card-block">
                <h4>@ViewBag.TicketsActivos</h4>
                <p class="m-b-0">Tickets Activos</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-c-yellow text-white">
            <div class="card-block">
                <h4>L @string.Format("{0:N2}", ViewBag.IngresosHoy)</h4>
                <p class="m-b-0">Ingresos de Hoy</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card text-center">
            <div class="card-block">
                <h5>Total Facturas</h5>
                <h3>@ViewBag.TotalFacturas</h3>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card text-center">
            <div class="card-block">
                <h5>Total Pagos</h5>
                <h3>@ViewBag.TotalPagos</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-8 col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Tickets Activos</h5>
            </div>
            <div class="card-block">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered">
                        <tr>
                            <th>Placa</th>
                            <th>Cliente</th>
                            <th>Espacio</th>
                            <th>Entrada</th>
                            <th>Estado</th>
                        </tr>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(item.Vehiculo != null ? item.Vehiculo.Placa : "")</td>
                                    <td>@(item.Cliente != null ? item.Cliente.Nombre + " " + item.Cliente.Apellido : "")</td>
                                    <td>@(item.Espacio != null ? item.Espacio.Codigo : "")</td>
                                    <td>@item.Entrada</td>
                                    <td>
                                        @if (item.Estado == "ACTIVO")
                                        {
                                            <span class="badge badge-success">ACTIVO</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">CERRADO</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No hay tickets activos.</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Usuarios Activos</h5>
            </div>
            <div class="card-block">
                <div class="row text-center">
                    @if (ViewBag.Usuarios != null)
                    {
                        foreach (var u in ViewBag.Usuarios)
                        {
                            string foto = string.IsNullOrEmpty(u.Foto) ? "default.png" : u.Foto;

                            <div class="col-md-6 m-b-20">
                                <div class="card">
                                    <div class="card-block">
                                        <img src="@Url.Content("~/Content/uploads/usuarios/" + foto)"
                                             class="img-radius"
                                             style="width:70px; height:70px; object-fit:cover;" />

                                        <h6 class="m-t-10">@u.Nombre @u.Apellido</h6>
                                        <small class="text-muted">@u.Nombre</small>
                                        <br />
                                        @if (u.Rol != null)
                                        {
                                            <small class="text-muted">@u.Rol.Nombre</small>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-6 col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Últimos Pagos</h5>
            </div>
            <div class="card-block">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered">
                        <tr>
                            <th>Factura</th>
                            <th>Monto</th>
                            <th>Fecha</th>
                        </tr>

                        @if (ViewBag.Pagos != null)
                        {
                            foreach (var p in ViewBag.Pagos)
                            {
                                <tr>
                                    <td>@(p.Factura != null ? p.Factura.Folio : "")</td>
                                    <td>L @string.Format("{0:N2}", p.Monto)</td>
                                    <td>@p.FechaPago</td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6 col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Actividad Reciente</h5>
            </div>
            <div class="card-block">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered">
                        <tr>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Fecha</th>
                        </tr>

                        @if (ViewBag.Auditoria != null)
                        {
                            foreach (var a in ViewBag.Auditoria)
                            {
                                <tr>
                                    <td>@(a.Usuario != null ? a.Usuario.Nombre + " " + a.Usuario.Apellido : "")</td>
                                    <td>@a.Accion</td>
                                    <td>@a.Fecha</td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
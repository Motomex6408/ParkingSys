@model List<Entity.General.eKardex>

<h2>Kardex</h2>

<table class="table table-striped table-bordered">
    <tr>
        <th>Vehículo</th>
        <th>Movimiento</th>
        <th>Fecha</th>
        <th>Monto</th>
        <th>Descripción</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@(item.Ticket != null && item.Ticket.Vehiculo != null ? item.Ticket.Vehiculo.Placa : "")</td>
            <td>@item.TipoMovimiento</td>
            <td>@item.Fecha</td>
            <td>@item.Monto</td>
            <td>@item.Descripcion</td>
        </tr>
    }
</table>
@model Entity.Estructura.eZona

@{
    ViewBag.Title = "Editar Zona";
}

<h2>Editar Zona</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)

    <div class="form-horizontal">
        <hr />

        @if (ViewBag.message != null)
        {
            <div class="text-danger">@ViewBag.message</div>
        }

        <div class="form-group">
            @Html.LabelFor(m => m.IdSucursal, "Sucursal", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("IdSucursal", null, "-- Seleccione --", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.IdSucursal)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.Nombre, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.Nombre)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Descripcion, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.Descripcion, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.Descripcion)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Nivel, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.Nivel, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.Nivel)
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Guardar" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Volver", "Index")
</div>
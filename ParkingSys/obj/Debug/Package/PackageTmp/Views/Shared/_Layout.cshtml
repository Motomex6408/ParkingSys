@{
    Layout = null;

    string nombreUsuario = Session["Nombre"] != null ? Session["Nombre"].ToString() : "Invitado";
    string userName = Session["UserName"] != null ? Session["UserName"].ToString() : "";
    string fotoUsuario = Session["Foto"] != null ? Session["Foto"].ToString() : "default.png";
    string rolUsuario = Session["Rol"] != null ? Session["Rol"].ToString() : "";
    bool esAdmin = rolUsuario == "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <title>@ViewBag.Title - ParkingSys</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link rel="icon" href="@Url.Content("~/assets/images/favicon.ico")" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600,700" rel="stylesheet">

    <link rel="stylesheet" href="@Url.Content("~/assets/pages/waves/css/waves.min.css")" type="text/css" media="all">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/css/bootstrap/css/bootstrap.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/icon/themify-icons/themify-icons.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/css/font-awesome-n.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/css/font-awesome.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/css/jquery.mCustomScrollbar.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/css/style.css")">
</head>
<body>
    <div class="theme-loader">
        <div class="loader-track">
            <div class="preloader-wrapper">
                <div class="spinner-layer spinner-blue">
                    <div class="circle-clipper left"><div class="circle"></div></div>
                    <div class="gap-patch"><div class="circle"></div></div>
                    <div class="circle-clipper right"><div class="circle"></div></div>
                </div>
                <div class="spinner-layer spinner-red">
                    <div class="circle-clipper left"><div class="circle"></div></div>
                    <div class="gap-patch"><div class="circle"></div></div>
                    <div class="circle-clipper right"><div class="circle"></div></div>
                </div>
                <div class="spinner-layer spinner-yellow">
                    <div class="circle-clipper left"><div class="circle"></div></div>
                    <div class="gap-patch"><div class="circle"></div></div>
                    <div class="circle-clipper right"><div class="circle"></div></div>
                </div>
                <div class="spinner-layer spinner-green">
                    <div class="circle-clipper left"><div class="circle"></div></div>
                    <div class="gap-patch"><div class="circle"></div></div>
                    <div class="circle-clipper right"><div class="circle"></div></div>
                </div>
            </div>
        </div>
    </div>

    <div id="pcoded" class="pcoded">
        <div class="pcoded-overlay-box"></div>
        <div class="pcoded-container navbar-wrapper">

            <nav class="navbar header-navbar pcoded-header">
                <div class="navbar-wrapper">
                    <div class="navbar-logo">
                        <a class="mobile-menu waves-effect waves-light" id="mobile-collapse" href="#!">
                            <i class="ti-menu"></i>
                        </a>

                        <a href="@Url.Action("Index", "Home")">
                            <img class="img-fluid" src="@Url.Content("~/assets/images/logo.png")" alt="Logo" />
                        </a>

                        <a class="mobile-options waves-effect waves-light">
                            <i class="ti-more"></i>
                        </a>
                    </div>

                    <div class="navbar-container container-fluid">
                        <ul class="nav-left">
                            <li>
                                <div class="sidebar_toggle">
                                    <a href="javascript:void(0)"><i class="ti-menu"></i></a>
                                </div>
                            </li>
                        </ul>

                        <ul class="nav-right">
                            <li class="user-profile header-notification">
                                <a href="#!" class="waves-effect waves-light">
                                    <img src="@Url.Content("~/Content/uploads/usuarios/" + fotoUsuario)" class="img-radius" alt="User">
                                    <span>@nombreUsuario</span>
                                    <i class="ti-angle-down"></i>
                                </a>
                                <ul class="show-notification profile-notification">
                                    <li>
                                        <div style="padding:10px 20px;">
                                            <strong>@nombreUsuario</strong><br />
                                            <small>@userName</small><br />
                                            <small>@rolUsuario</small>
                                        </div>
                                    </li>
                                    <li class="waves-effect waves-light">
                                        <a href="@Url.Action("Logout", "User")">
                                            <i class="ti-layout-sidebar-left"></i> Cerrar sesión
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <div class="pcoded-main-container">
                <div class="pcoded-wrapper">

                    <nav class="pcoded-navbar">
                        <div class="sidebar_toggle">
                            <a href="#"><i class="icon-close icons"></i></a>
                        </div>

                        <div class="pcoded-inner-navbar main-menu">

                            <div class="">
                                <div class="main-menu-header">
                                    <img class="img-80 img-radius" src="@Url.Content("~/Content/uploads/usuarios/" + fotoUsuario)" alt="User-Profile-Image">
                                    <div class="user-details">
                                        <span id="more-details">@nombreUsuario <i class="fa fa-caret-down"></i></span>
                                        <small class="d-block text-muted">@rolUsuario</small>
                                    </div>
                                </div>
                                <div class="main-menu-content">
                                    <ul>
                                        <li class="more-details">
                                            <a href="@Url.Action("Index", "Home")"><i class="ti-home"></i>Dashboard</a>
                                            <a href="@Url.Action("Logout", "User")"><i class="ti-layout-sidebar-left"></i>Cerrar sesión</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="pcoded-navigation-label">Principal</div>
                            <ul class="pcoded-item pcoded-left-item">
                                <li>
                                    <a href="@Url.Action("Index", "Home")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-home"></i></span>
                                        <span class="pcoded-mtext">Dashboard</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                            </ul>

                            @if (esAdmin)
                            {
                                <div class="pcoded-navigation-label">Mantenimiento</div>
                                <ul class="pcoded-item pcoded-left-item">
                                    <li>
                                        <a href="@Url.Action("Index", "Usuario")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-user"></i></span>
                                            <span class="pcoded-mtext">Usuarios</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "Rol")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-id-badge"></i></span>
                                            <span class="pcoded-mtext">Roles</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "MetodoPago")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-money"></i></span>
                                            <span class="pcoded-mtext">Métodos de Pago</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "Tarifa")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-tag"></i></span>
                                            <span class="pcoded-mtext">Tarifas</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "Auditoria")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-write"></i></span>
                                            <span class="pcoded-mtext">Auditoría</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                </ul>

                                <div class="pcoded-navigation-label">Estructura</div>
                                <ul class="pcoded-item pcoded-left-item">
                                    <li>
                                        <a href="@Url.Action("Index", "Sucursal")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-map-alt"></i></span>
                                            <span class="pcoded-mtext">Sucursales</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "Zona")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-layout-grid2"></i></span>
                                            <span class="pcoded-mtext">Zonas</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "Espacio")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-layout-column3"></i></span>
                                            <span class="pcoded-mtext">Espacios</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="@Url.Action("Index", "TipoVehiculo")" class="waves-effect waves-dark">
                                            <span class="pcoded-micon"><i class="ti-car"></i></span>
                                            <span class="pcoded-mtext">Tipo Vehículo</span>
                                            <span class="pcoded-mcaret"></span>
                                        </a>
                                    </li>
                                </ul>
                            }

                            <div class="pcoded-navigation-label">Operación</div>
                            <ul class="pcoded-item pcoded-left-item">
                                <li>
                                    <a href="@Url.Action("Index", "Cliente")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-user"></i></span>
                                        <span class="pcoded-mtext">Clientes</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", "Vehiculo")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-truck"></i></span>
                                        <span class="pcoded-mtext">Vehículos</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", "Ticket")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-ticket"></i></span>
                                        <span class="pcoded-mtext">Tickets</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", "Kardex")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-receipt"></i></span>
                                        <span class="pcoded-mtext">Kardex</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                            </ul>

                            <div class="pcoded-navigation-label">Facturación</div>
                            <ul class="pcoded-item pcoded-left-item">
                                <li>
                                    <a href="@Url.Action("Index", "Factura")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-file"></i></span>
                                        <span class="pcoded-mtext">Facturas</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", "Pago")" class="waves-effect waves-dark">
                                        <span class="pcoded-micon"><i class="ti-wallet"></i></span>
                                        <span class="pcoded-mtext">Pagos</span>
                                        <span class="pcoded-mcaret"></span>
                                    </a>
                                </li>
                            </ul>

                           

                        </div>
                    </nav>

                    <div class="pcoded-content">
                        <div class="page-header">
                            <div class="page-block">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="page-header-title">
                                            <h5 class="m-b-10">@ViewBag.Title</h5>
                                            <p class="m-b-0">Sistema de gestión de parqueo</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <ul class="breadcrumb">
                                            <li class="breadcrumb-item">
                                                <a href="@Url.Action("Index", "Home")"><i class="fa fa-home"></i></a>
                                            </li>
                                            <li class="breadcrumb-item">
                                                <a href="#!">@ViewBag.Title</a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pcoded-inner-content">
                            <div class="main-body">
                                <div class="page-wrapper">
                                    <div class="page-body">
                                        @RenderBody()
                                    </div>
                                </div>
                                <div id="styleSelector"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script type="text/javascript" src="@Url.Content("~/assets/js/jquery/jquery.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/jquery-ui/jquery-ui.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/popper.js/popper.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/bootstrap/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("~/assets/pages/waves/js/waves.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/jquery-slimscroll/jquery.slimscroll.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/jquery.mCustomScrollbar.concat.min.js")"></script>
    <script src="@Url.Content("~/assets/js/pcoded.min.js")"></script>
    <script src="@Url.Content("~/assets/js/vertical/vertical-layout.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/assets/js/script.js")"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
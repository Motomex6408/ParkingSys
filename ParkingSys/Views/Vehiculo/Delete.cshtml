@model Entity.General.eVehiculo

@{
    ViewBag.Title = "Eliminar Vehículo";
}


<h2>Eliminar Vehículo</h2>

<h4>¿Estás seguro que deseas eliminar esto?</h4>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Placa</dt>
        <dd>@Model.Placa</dd>

        <dt>Tipo de Vehículo</dt>
        <dd>@(Model.TipoVehiculo != null ? Model.TipoVehiculo.Nombre : "")</dd>

        <dt>Marca</dt>
        <dd>@Model.Marca</dd>

        <dt>Modelo</dt>
        <dd>@Model.Modelo</dd>

        <dt>Color</dt>
        <dd>@Model.Color</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <input type="submit" value="Eliminar" class="btn btn-danger" />
    }

    <br />
    @Html.ActionLink("Cancelar", "Index")
</div>
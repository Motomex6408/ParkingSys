@model List<Entity.General.eVehiculo>

@{
    ViewBag.Title = "Vehículo";
}

<h2>Vehículo</h2>

<p>
    @Html.ActionLink("Nuevo", "Create")
</p>

<table class="table">
    <tr>
        <th>Placa</th>
        <th>Tipo de Vehículo</th>
        <th>Marca</th>
        <th>Modelo</th>
        <th>Color</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Placa</td>
            <td>@(item.TipoVehiculo != null ? item.TipoVehiculo.Nombre : "")</td>
            <td>@item.Marca</td>
            <td>@item.Modelo</td>
            <td>@item.Color</td>
            <td>
                @Html.ActionLink("Editar", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Eliminar", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>
@model Entity.General.eTicket

@{
    ViewBag.Title = "Nuevo Ticket";
}

<h2>Nuevo Ticket</h2>

<div class="card">
    <div class="card-header">
        <h5>Registrar Entrada</h5>
    </div>
    <div class="card-block">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            if (ViewBag.message != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.message
                </div>
            }

            <div class="form-horizontal">
                <div class="form-group">
                    @Html.LabelFor(model => model.IdVehiculo, "Vehículo", new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.DropDownList("IdVehiculo", null, "-- Seleccione --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdVehiculo, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.IdCliente, "Cliente", new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.DropDownList("IdCliente", null, "-- Seleccione --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdCliente, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.IdEspacio, "Espacio", new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.DropDownList("IdEspacio", null, "-- Seleccione --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdEspacio, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.IdUsuario, "Usuario", new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.DropDownList("IdUsuario", null, "-- Seleccione --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdUsuario, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.IdTarifa, "Tarifa", new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.DropDownList("IdTarifa", null, "-- Seleccione --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdTarifa, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="text-right">
                    <input type="submit" value="Guardar" class="btn btn-success" />
                    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
                </div>
            </div>
        }
    </div>
</div>